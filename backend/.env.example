# =============================================================================
# Oraculum Trading Platform -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is already in .gitignore.
# =============================================================================

# === Environment ===
ENVIRONMENT=development          # development | production | test

# === Database (PostgreSQL) ===
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=              # REQUIRED -- set a strong password
POSTGRES_DB=trading_platform
POSTGRES_HOST=postgres           # 'postgres' for Docker, 'localhost' for local dev
POSTGRES_PORT=5432
# DATABASE_URL=                  # Optional -- overrides individual POSTGRES_* vars

# === Security (REQUIRED for production) ===
JWT_SECRET_KEY=                  # Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=                      # Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=                  # Fernet key for strategy encryption
                                 # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENFORCE_HTTPS=false              # Set to true in production behind TLS proxy

# === Market Data ===
DATA_PROVIDER=yahoo              # yahoo | polygon | alpaca | iex
ALPHA_VANTAGE_API_KEY=           # https://www.alphavantage.co/support/#api-key
POLYGON_API_KEY=                 # https://polygon.io/dashboard/api-keys
IEX_API_KEY=                     # https://iexcloud.io/console/tokens
ALPACA_API_KEY=                  # https://app.alpaca.markets/paper/dashboard/overview
ALPACA_SECRET=                   # Alpaca API secret key

# === AI / LLM ===
ANTHROPIC_API_KEY=               # https://console.anthropic.com/settings/keys
OPENAI_API_KEY=                  # https://platform.openai.com/api-keys
GEMINI_API_KEY=                  # https://aistudio.google.com/app/apikey
DEEPSEEK_API_KEY=                # https://platform.deepseek.com/api_keys

# === Macro Economic Data ===
FRED_API_KEY=                    # https://fred.stlouisfed.org/docs/api/api_key.html
BLS_API_KEY=                     # https://data.bls.gov/registrationEngine/

# === Sentiment / News ===
NEWSAPI_KEY=                     # https://newsapi.org/account
TWITTER_BEARER_TOKEN=            # https://developer.twitter.com/en/portal/dashboard
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# === Alerts (optional) ===
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
TO_EMAIL=

SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# === Redis ===
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=false

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000   # Backend URL the frontend calls
NEXT_PUBLIC_WS_URL=ws://localhost:8000     # WebSocket URL

# === Observability ===
LOG_LEVEL=INFO
SENTRY_DSN=                      # Optional -- Sentry error tracking DSN

# === Monitoring (Grafana) ===
GRAFANA_ADMIN_USER=admin         # Grafana admin username
GRAFANA_ADMIN_PASSWORD=oraculum  # CHANGE in production

# === Stripe (Marketplace Payments) ===
STRIPE_SECRET_KEY=              # https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=          # From Stripe webhook settings

# === Super User ===
ADMIN_EMAIL=                    # Auto-created admin account on first startup
ADMIN_PASSWORD=
ADMIN_USERNAME=
